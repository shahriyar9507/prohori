# ─── PRAHARI backend configuration (copy to .env; never commit .env) ──────

ENVIRONMENT=development

# Comma-separated origins allowed to call the API (the React dev server, etc.)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ─── DRISHTI ──────────────────────────────────────────────────────────────
# Serve live GDELT (True) or the cached demo snapshot (False, default & safest).
DRISHTI_USE_LIVE_GDELT=False
GDELT_TIMEOUT_SECONDS=15

# ─── LLM provider (Do/Avoid brief, Bangla Q&A) ────────────────────────────
# Sovereign option: point LLM_BASE_URL at a local Ollama/vLLM OpenAI-compatible
# endpoint (e.g. http://localhost:11434/v1) and set any non-empty LLM_API_KEY.
# Hosted option: use a provider's base URL + real key.
# Leave LLM_API_KEY empty to use the deterministic fallback brief (demo-safe).
LLM_API_KEY=
LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
LLM_MODEL=gemini-2.5-flash-lite
